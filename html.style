<!DOCTYPE html><html lang="en">
<head>
<meta charset="UTF-8">
<title>Instagram Clone</title>
<link rel="stylesheet" href="style.css">
</head><body><div class="container"><div class="login-box">
<h1 class="logo">Instagram</h1><input type="text" placeholder="Phone number, username, or email">
<input type="password" placeholder="Password"><button>Log In</button>

<div class="divider">OR</div><p class="facebook">Log in with Facebook</p>
<p class="forgot">Forgot password?</p></div><div class="signup-box">
<p>Don't have an account? <span>Sign up</span></p>
</div></div></body>
</html>
